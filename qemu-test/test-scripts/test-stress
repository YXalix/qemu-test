#!/bin/sh
echo "=== Memory Pressure Test ==="
echo ""
echo "Current memory:"
free -h
echo ""
echo "Creating memory pressure..."
for i in $(seq 1 10); do
    echo "  Allocating 100MB..."
    dd if=/dev/zero of=/tmp/stress_$i bs=1M count=100 2>/dev/null
    sleep 0.5
    free -h | grep -E "(Mem|Swap)"
done
echo ""
echo "Cleaning up..."
rm -f /tmp/stress_*
echo "Final memory:"
free -h
