#!/bin/sh
echo "=== ETMEM Test ==="
echo ""
if [ -f /sys/kernel/mm/swap/kernel_swap_enable ]; then
    echo "ETMEM kernel_swap_enable: $(cat /sys/kernel/mm/swap/kernel_swap_enable)"
else
    echo "ETMEM interface not available"
fi
echo ""
echo "ETMEM reclaim setting:"
cat /proc/sys/vm/etmem_reclaim 2>/dev/null || echo "  /proc/sys/vm/etmem_reclaim not found"
echo ""
echo "Swap status:"
cat /proc/swaps
