#!/bin/sh
# SPDX-License-Identifier: GPL-2.0
# Comprehensive Hugetlb Swap E2E Test
# Tests the complete hugetlb swap workflow from allocation to swap-in

echo "=========================================="
echo "Hugetlb Swap Comprehensive E2E Test"
echo "=========================================="
echo ""

# Color codes for output (if terminal supports it)
PASS="\033[32mPASS\033[0m"
FAIL="\033[31mFAIL\033[0m"
SKIP="\033[33mSKIP\033[0m"
INFO="\033[34mINFO\033[0m"

# Test counters
TESTS_TOTAL=0
TESTS_PASSED=0
TESTS_FAILED=0
TESTS_SKIPPED=0

# Helper functions
pass_test() {
    TESTS_TOTAL=$((TESTS_TOTAL + 1))
    TESTS_PASSED=$((TESTS_PASSED + 1))
    echo -e "  [$PASS] $1"
}

fail_test() {
    TESTS_TOTAL=$((TESTS_TOTAL + 1))
    TESTS_FAILED=$((TESTS_FAILED + 1))
    echo -e "  [$FAIL] $1"
}

skip_test() {
    TESTS_TOTAL=$((TESTS_TOTAL + 1))
    TESTS_SKIPPED=$((TESTS_SKIPPED + 1))
    echo -e "  [$SKIP] $1"
}

info_msg() {
    echo -e "  [$INFO] $1"
}

# Test 1: Prerequisites Check
test_prerequisites() {
    echo "--- Test 1: Prerequisites ---"

    # Check CONFIG_HUGETLB_SWAP
    if [ -f /proc/config.gz ]; then
        if zcat /proc/config.gz 2>/dev/null | grep -q "CONFIG_HUGETLB_SWAP=y"; then
            pass_test "CONFIG_HUGETLB_SWAP enabled"
        else
            fail_test "CONFIG_HUGETLB_SWAP not enabled"
        fi
    else
        skip_test "Cannot check kernel config"
    fi

    # Check swap is configured (partition, file, or zram)
    if free | grep -q Swap && [ "$(free | awk '/Swap:/{print $2}')" -gt 0 ]; then
        pass_test "Swap is configured"
        free -h | grep Swap
    elif [ -s /proc/swaps ] && grep -qE "partition|file|/dev/zram" /proc/swaps 2>/dev/null; then
        pass_test "Swap is configured"
        swapon -s | head -2
    else
        fail_test "No swap configured"
    fi

    # Check hugepage support
    if [ -d /sys/kernel/mm/hugepages ]; then
        pass_test "Hugetlb support available"
    else
        fail_test "Hugetlb support not available"
    fi

    # Check KUnit tests available
    if [ -d /sys/kernel/debug/kunit ]; then
        pass_test "KUnit framework available"
    else
        skip_test "KUnit debugfs not mounted"
    fi

    echo ""
}

# Test 2: Hugetlb Allocation Test
test_hugetlb_allocation() {
    echo "--- Test 2: Hugetlb Allocation ---"

    local hp_path="/sys/kernel/mm/hugepages/hugepages-2048kB"
    if [ ! -d "$hp_path" ]; then
        skip_test "2MB hugepages not supported"
        echo ""
        return
    fi

    local orig_nr=$(cat "$hp_path/nr_hugepages")

    # Reserve hugepages
    echo 5 > "$hp_path/nr_hugepages" 2>/dev/null
    sleep 0.5
    local actual=$(cat "$hp_path/nr_hugepages")

    if [ "$actual" -ge 5 ]; then
        pass_test "Reserved $actual hugepages"
    else
        fail_test "Only reserved $actual hugepages (requested 5)"
    fi

    # Check free count
    local free=$(cat "$hp_path/free_hugepages")
    if [ "$free" -ge 5 ]; then
        pass_test "All $free hugepages are free"
    else
        info_msg "Only $free hugepages free"
    fi

    # Restore
    echo "$orig_nr" > "$hp_path/nr_hugepages" 2>/dev/null
    pass_test "Restored original hugepage count"

    echo ""
}

# Test 3: Hugetlbfs Functionality
test_hugetlbfs() {
    echo "--- Test 3: Hugetlbfs Functionality ---"

    if [ ! -d /mnt/huge ]; then
        skip_test "/mnt/huge not available"
        echo ""
        return
    fi

    if ! mount | grep -qE "hugetlbfs.*mnt/huge|/mnt/huge.*hugetlbfs"; then
        skip_test "hugetlbfs not mounted"
        echo ""
        return
    fi

    pass_test "hugetlbfs mounted at /mnt/huge"

    # Test file allocation
    local hp_path="/sys/kernel/mm/hugepages/hugepages-2048kB"
    local orig_nr=$(cat "$hp_path/nr_hugepages")

    # Reserve hugepages first
    echo 5 > "$hp_path/nr_hugepages" 2>/dev/null
    sleep 1
    local reserved=$(cat "$hp_path/nr_hugepages")

    if [ "$reserved" -lt 2 ]; then
        skip_test "Could not reserve hugepages (only $reserved available)"
        echo "$orig_nr" > "$hp_path/nr_hugepages" 2>/dev/null
        echo ""
        return
    fi

    # Try to allocate using truncate (creates a file of exact hugepage size)
    # Note: hugetlbfs requires writes to be exactly hugepage size aligned
    if truncate -s 2097152 /mnt/huge/testfile 2>/dev/null; then
        pass_test "Allocated 1 hugepage via hugetlbfs using truncate"
    else
        info_msg "truncate failed, trying fallocate..."
        # Try fallocate as fallback
        if fallocate -l 2097152 /mnt/huge/testfile 2>/dev/null; then
            pass_test "Allocated 1 hugepage via hugetlbfs using fallocate"
        else
            info_msg "Hugepages available: $(cat $hp_path/nr_hugepages)"
            info_msg "Hugepages free: $(cat $hp_path/free_hugepages)"
            fail_test "Could not allocate via hugetlbfs"
        fi
    fi

    # Skip the rest of the test if allocation failed
    if [ ! -f /mnt/huge/testfile ]; then
        echo "$orig_nr" > "$hp_path/nr_hugepages" 2>/dev/null
        echo ""
        return
    fi

    # For hugetlbfs, we can read/write the file normally once allocated
    # The file is already the right size, let's verify we can read/write it
    if echo "TEST" > /mnt/huge/testfile 2>/dev/null; then
        if [ -s /mnt/huge/testfile ]; then
            pass_test "Data written and file is accessible"
        fi
    fi

    rm -f /mnt/huge/testfile
    echo "$orig_nr" > "$hp_path/nr_hugepages" 2>/dev/null

    echo ""
}

# Test 4: ETMEM Interface
test_etmem_interface() {
    echo "--- Test 4: ETMEM Interface ---"

    if [ -f /proc/etmem ]; then
        pass_test "/proc/etmem exists"
    else
        skip_test "/proc/etmem not found"
    fi

    if [ -f /sys/kernel/mm/swap/kernel_swap_enable ]; then
        pass_test "kernel_swap_enable sysfs exists"

        # Test enable/disable
        local orig=$(cat /sys/kernel/mm/swap/kernel_swap_enable)
        echo "false" > /sys/kernel/mm/swap/kernel_swap_enable 2>/dev/null
        if [ "$(cat /sys/kernel/mm/swap/kernel_swap_enable)" = "false" ]; then
            pass_test "Can disable kernel swap"
        fi
        echo "$orig" > /sys/kernel/mm/swap/kernel_swap_enable 2>/dev/null
    else
        skip_test "kernel_swap_enable not available"
    fi

    echo ""
}

# Test 5: Memory Pressure and Swap
test_memory_pressure() {
    echo "--- Test 5: Memory Pressure & Swap Activity ---"

    # Record swap stats before
    local swap_in_before=$(grep "pswpin" /proc/vmstat | awk '{print $2}')
    local swap_out_before=$(grep "pswpout" /proc/vmstat | awk '{print $2}')

    info_msg "Swap in before: $swap_in_before pages"
    info_msg "Swap out before: $swap_out_before pages"

    # Create memory pressure
    info_msg "Creating memory pressure..."
    for i in $(seq 1 5); do
        dd if=/dev/zero of=/tmp/pressure_$i bs=1M count=100 2>/dev/null
        sleep 0.5
    done

    # Record swap stats after
    local swap_in_after=$(grep "pswpin" /proc/vmstat | awk '{print $2}')
    local swap_out_after=$(grep "pswpout" /proc/vmstat | awk '{print $2}')

    rm -f /tmp/pressure_*

    local swap_in_diff=$((swap_in_after - swap_in_before))
    local swap_out_diff=$((swap_out_after - swap_out_before))

    info_msg "Swap activity during test:"
    info_msg "  Swap in: $swap_in_diff pages"
    info_msg "  Swap out: $swap_out_diff pages"

    if [ "$swap_out_diff" -gt 0 ] || [ "$swap_in_diff" -gt 0 ]; then
        pass_test "Swap activity detected"
    else
        info_msg "No swap activity (may need more memory pressure)"
    fi

    echo ""
}

# Test 6: KUnit Test Execution
test_kunit() {
    echo "--- Test 6: KUnit Test Execution ---"

    if [ ! -d /sys/kernel/debug/kunit ]; then
        skip_test "KUnit debugfs not available"
        echo ""
        return
    fi

    # Check for hugetlb test suites
    local found_suites=0
    for suite in /sys/kernel/debug/kunit/hugetlb-*; do
        if [ -d "$suite" ]; then
            found_suites=$((found_suites + 1))
            local suite_name=$(basename "$suite")
            pass_test "Found test suite: $suite_name"

            # Check results if available
            if [ -f "$suite/results" ]; then
                local passed=$(grep -c "PASSED" "$suite/results" 2>/dev/null || echo "0")
                local failed=$(grep -c "FAILED" "$suite/results" 2>/dev/null || echo "0")
                info_msg "  Results: $passed passed, $failed failed"
            fi
        fi
    done

    if [ "$found_suites" -eq 0 ]; then
        info_msg "No hugetlb test suites found (may need to load test module)"
    fi

    echo ""
}

# Test 7: Stress Test
test_stress() {
    echo "--- Test 7: Stress Test ---"

    local hp_path="/sys/kernel/mm/hugepages/hugepages-2048kB"
    local orig_nr=$(cat "$hp_path/nr_hugepages")

    # Reserve and allocate multiple times
    info_msg "Running allocation/deallocation cycles..."
    local cycles=0
    local max_cycles=5

    while [ $cycles -lt $max_cycles ]; do
        cycles=$((cycles + 1))

        # Reserve
        echo 3 > "$hp_path/nr_hugepages" 2>/dev/null
        sleep 0.2

        # Check
        local current=$(cat "$hp_path/nr_hugepages")
        if [ "$current" -ge 3 ]; then
            pass_test "Cycle $cycles: Reserved 3 hugepages"
        else
            fail_test "Cycle $cycles: Only reserved $current hugepages"
        fi

        # Free
        echo 0 > "$hp_path/nr_hugepages" 2>/dev/null
    done

    echo "$orig_nr" > "$hp_path/nr_hugepages" 2>/dev/null
    pass_test "Completed $max_cycles stress cycles"

    echo ""
}

# Test 8: Summary
test_summary() {
    echo "=========================================="
    echo "Test Summary"
    echo "=========================================="
    echo "  Total tests:  $TESTS_TOTAL"
    echo -e "  Passed:       $TESTS_PASSED"
    echo -e "  Failed:       $TESTS_FAILED"
    echo -e "  Skipped:      $TESTS_SKIPPED"
    echo ""

    if [ "$TESTS_FAILED" -eq 0 ]; then
        echo -e "\033[32mAll critical tests passed!\033[0m"
    else
        echo -e "\033[31mSome tests failed. Check output above.\033[0m"
    fi

    echo ""
    echo "System state:"
    echo "  Memory:"
    free -h | grep -E "(Mem|Swap:)" | head -2
    echo "  Hugepages:"
    cat /sys/kernel/mm/hugepages/hugepages-2048kB/nr_hugepages 2>/dev/null || echo "    Not available"
}

# Main execution
main() {
    test_prerequisites
    test_hugetlb_allocation
    test_hugetlbfs
    test_etmem_interface
    test_memory_pressure
    test_kunit
    test_stress
    test_summary
}

# Run all tests
main
