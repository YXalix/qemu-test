#!/bin/sh
echo "=== Hugetlb Test ==="
echo ""
echo "Hugepage sizes available:"
ls /sys/kernel/mm/hugepages/
echo ""
echo "Current hugepage count:"
for hp in /sys/kernel/mm/hugepages/hugepages-*; do
    if [ -d "$hp" ]; then
        name=$(basename "$hp")
        nr=$(cat "$hp/nr_hugepages")
        echo "  $name: $nr"
    fi
done
echo ""
echo "Reserving 10 x 2MB hugepages..."
echo 10 > /sys/kernel/mm/hugepages/hugepages-2048kB/nr_hugepages
echo "Current count:"
cat /sys/kernel/mm/hugepages/hugepages-2048kB/nr_hugepages
echo ""
echo "Testing hugetlbfs allocation..."
# Use exact hugepage size (2097152 = 2MB) for hugetlbfs
dd if=/dev/zero of=/mnt/huge/testfile bs=2097152 count=5 2>/dev/null && echo "Success!" || echo "Failed"
rm -f /mnt/huge/testfile
echo ""
echo "Freeing hugepages..."
echo 0 > /sys/kernel/mm/hugepages/hugepages-2048kB/nr_hugepages
