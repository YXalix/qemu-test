#!/bin/sh
# Init script for hugetlb swap testing

# Mount essential filesystems
mount -t proc none /proc
mount -t sysfs none /sys
mount -t devtmpfs none /dev
mount -t tmpfs none /tmp
mount -t debugfs none /sys/kernel/debug 2>/dev/null || true

# Create necessary directories
mkdir -p /dev/pts /dev/shm
mount -t devpts devpts /dev/pts
mount -t tmpfs tmpfs /dev/shm

# Mount hugetlbfs with explicit pagesize for 2MB hugepages
mkdir -p /mnt/huge
if mount -t hugetlbfs -o pagesize=2M none /mnt/huge 2>/dev/null; then
    echo "  Hugetlbfs mounted at /mnt/huge (2MB)"
elif mount -t hugetlbfs none /mnt/huge 2>/dev/null; then
    echo "  Hugetlbfs mounted at /mnt/huge (default)"
else
    echo "  Failed to mount hugetlbfs"
fi

# Load kernel modules
echo "Loading kernel modules..."
for mod in /lib/modules/*.ko; do
    if [ -f "$mod" ]; then
        insmod "$mod" 2>/dev/null && echo "  Loaded: $(basename $mod)" || echo "  Failed: $(basename $mod)"
    fi
done
sleep 1

# Initialize and set up zram swap
echo "Setting up zram swap..."
if [ -f /sys/class/zram-control/hot_add ]; then
    # Modern zram interface
    ZRAM_DEV=$(cat /sys/class/zram-control/hot_add 2>/dev/null)
    if [ -n "$ZRAM_DEV" ]; then
        echo lz4 > /sys/block/zram${ZRAM_DEV}/comp_algorithm 2>/dev/null || echo lzo > /sys/block/zram${ZRAM_DEV}/comp_algorithm 2>/dev/null || true
        echo 536870912 > /sys/block/zram${ZRAM_DEV}/disksize 2>/dev/null
        if mkswap /dev/zram${ZRAM_DEV} 2>/dev/null && swapon /dev/zram${ZRAM_DEV} 2>/dev/null; then
            echo "  Zram swap enabled (512MB) on zram${ZRAM_DEV}"
        else
            echo "  Failed to setup zram${ZRAM_DEV}"
        fi
    fi
elif [ -d /sys/block/zram0 ]; then
    # Legacy zram interface - zram0 already exists
    echo lz4 > /sys/block/zram0/comp_algorithm 2>/dev/null || echo lzo > /sys/block/zram0/comp_algorithm 2>/dev/null || true
    echo 536870912 > /sys/block/zram0/disksize 2>/dev/null
    if mkswap /dev/zram0 2>/dev/null && swapon /dev/zram0 2>/dev/null; then
        echo "  Zram swap enabled (512MB)"
    else
        echo 0 > /sys/block/zram0/disksize 2>/dev/null || true
        echo "  Failed to setup zram0"
    fi
else
    echo "  Zram not available"
fi

# Also try disk-based swap if available
if [ -b /dev/vda ]; then
    echo "Checking for disk swap..."
    if mkswap /dev/vda 2>/dev/null && swapon /dev/vda 2>/dev/null; then
        echo "  Disk swap enabled"
    fi
fi

# Enable ETMEM
echo ""
echo "Enabling ETMEM..."
if [ -f /sys/kernel/mm/swap/kernel_swap_enable ]; then
    echo 1 > /sys/kernel/mm/swap/kernel_swap_enable 2>/dev/null || true
fi

# Print system info
echo ""
echo "=========================================="
echo "Hugetlb Swap Test Environment"
echo "=========================================="
echo "Kernel: $(uname -r)"
echo "Architecture: $(uname -m)"
echo ""
echo "Hugetlb Information:"
if [ -d /sys/kernel/mm/hugepages ]; then
    for hp in /sys/kernel/mm/hugepages/hugepages-*; do
        if [ -d "$hp" ]; then
            name=$(basename "$hp")
            nr=$(cat "$hp/nr_hugepages" 2>/dev/null || echo "N/A")
            free=$(cat "$hp/free_hugepages" 2>/dev/null || echo "N/A")
            echo "  $name: reserved=$nr, free=$free"
        fi
    done
else
    echo "  Hugepage support not available"
fi

echo ""
echo "Swap Information:"
cat /proc/swaps 2>/dev/null || echo "  No swap info available"

echo ""
echo "ETMEM Status:"
if [ -f /sys/kernel/mm/swap/kernel_swap_enable ]; then
    cat /sys/kernel/mm/swap/kernel_swap_enable
else
    echo "  Not available"
fi

echo ""
echo "Test commands: test-hugetlb, test-etmem, test-stress, hugetlb_alloc"
echo ""

# Wait a moment for everything to settle
echo "Waiting for system to settle..."
sleep 3

# Verify swap is ready
if [ -s /proc/swaps ]; then
    echo "Swap is ready:"
    swapon -s | head -2
else
    echo "WARNING: Swap not configured"
fi

# Check if running in auto-test mode (passed via kernel cmdline or env)
if grep -q "auto_test" /proc/cmdline 2>/dev/null || [ "$AUTO_TEST" = "1" ]; then
	echo ""
	echo "=========================================="
	echo "AUTO-TEST MODE: Running test suite..."
	echo "=========================================="
	echo ""

	# Run all test scripts
	TEST_FAILED=0
	for test_script in /tests/test-hugetlb /tests/test-etmem /tests/test-stress /tests/test-hugetlb-swap; do
		if [ -f "$test_script" ]; then
			echo ""
			echo "--- Running: $(basename $test_script) ---"
			if sh "$test_script"; then
				echo "PASSED: $(basename $test_script)"
			else
				echo "FAILED: $(basename $test_script)"
				TEST_FAILED=1
			fi
		fi
	done

	echo ""
	echo "=========================================="
	if [ $TEST_FAILED -eq 0 ]; then
		echo "TEST_COMPLETE: ALL TESTS PASSED"
	else
		echo "TEST_COMPLETE: SOME TESTS FAILED"
	fi
	echo "=========================================="

	# Power off the VM
	echo ""
	echo "Powering off..."
	poweroff -f
fi

# Start shell (interactive mode)
exec /bin/sh
