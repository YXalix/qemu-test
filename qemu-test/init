#!/bin/sh
# Init script for QEMU E2E testing

#==========================================
# Configuration
#==========================================
TESTS_DIR="/tests"
MODULES_DIR="/lib/modules"

#==========================================
# Helper Functions
#==========================================

LOG_INFO() {
    echo "[INFO] $1"
}

LOG_OK() {
    echo "  [OK] $1"
}

LOG_WARN() {
    echo "  [WARN] $1"
}

LOG_ERROR() {
    echo " [ERROR] $1"
}

# Mount essential filesystems
mount_filesystems() {
    LOG_INFO "Mounting filesystems..."

    mount -t proc none /proc
    mount -t sysfs none /sys
    mount -t devtmpfs none /dev
    mount -t tmpfs none /tmp
    mount -t debugfs none /sys/kernel/debug 2>/dev/null || true

    mkdir -p /dev/pts /dev/shm
    mount -t devpts devpts /dev/pts
    mount -t tmpfs tmpfs /dev/shm

    LOG_OK "Filesystems mounted"
}

# Load kernel modules
load_modules() {
    LOG_INFO "Loading kernel modules..."

    local loaded=0

    # NVMe support
    for mod in crc64 crc64-rocksoft t10-pi nvme-core nvme; do
        if modprobe "$mod" 2>/dev/null || \
           insmod "$MODULES_DIR/${mod}.ko" 2>/dev/null; then
            loaded=$((loaded + 1))
        fi
    done

    # Virtio drivers
    for mod in virtio virtio_ring virtio_blk virtio_pci; do
        if modprobe "$mod" 2>/dev/null || \
           insmod "$MODULES_DIR/${mod}.ko" 2>/dev/null; then
            loaded=$((loaded + 1))
        fi
    done

    # ublk driver
    if modprobe ublk 2>/dev/null || \
       insmod "$MODULES_DIR/ublk_drv.ko" 2>/dev/null; then
        LOG_OK "ublk module loaded"
        loaded=$((loaded + 1))
    else
        LOG_WARN "ublk module not found"
    fi

    LOG_INFO "Modules: $loaded loaded"
}

# Print system status information
print_status() {
    echo ""
    echo "=========================================="
    echo "QEMU E2E Test Environment"
    echo "=========================================="
    echo "Kernel: $(uname -r)"
    echo "Architecture: $(uname -m)"
    echo ""

    # Block devices
    echo "Block Devices:"
    ls /sys/class/block/ 2>/dev/null | sed 's/^/  /' || echo "  No block devices found"

    # ublk status
    echo ""
    echo "ublk Status:"
    if [ -e /dev/ublk-control ]; then
        echo "  ublk-control: available"
        ls /dev/ublkb* 2>/dev/null | sed 's/^/  /' || echo "  No ublk devices"
    else
        echo "  ublk-control: not available"
    fi

    # Test data files
    echo ""
    echo "Test Data Files:"
    if [ -f /data/testfile1.bin ]; then
        ls -lh /data/testfile*.bin 2>/dev/null | awk '{print "  " $9 " (" $5 ")"}'
    else
        echo "  No test files created yet"
    fi

    echo ""
    echo "Test commands:"
    echo "  Run tests from $TESTS_DIR"
    echo "  ublk add -t loop -f /data/testfile1.bin -n 0  # Create ublk device"
    echo ""
}

# Run all tests in /tests directory
run_auto_tests() {
    echo ""
    echo "=========================================="
    echo "AUTO-TEST MODE: Running test suite..."
    echo "=========================================="
    echo ""

    local test_failed=0
    local test_count=0
    local pass_count=0

    for test_exe in "$TESTS_DIR"/*; do
        if [ -f "$test_exe" ] && [ -x "$test_exe" ]; then
            test_count=$((test_count + 1))
            local test_name=$(basename "$test_exe")
            echo ""
            echo "--- Running: $test_name ---"
            if "$test_exe"; then
                echo "PASSED: $test_name"
                pass_count=$((pass_count + 1))
            else
                echo "FAILED: $test_name"
                test_failed=1
            fi
        fi
    done

    if [ $test_count -eq 0 ]; then
        LOG_WARN "No tests found in $TESTS_DIR"
    fi

    echo ""
    echo "=========================================="
    echo "Test Results: $pass_count/$test_count passed"
    if [ $test_failed -eq 0 ]; then
        echo "TEST_COMPLETE: ALL TESTS PASSED"
    else
        echo "TEST_COMPLETE: SOME TESTS FAILED"
    fi
    echo "=========================================="

    return $test_failed
}

# Power off the VM
power_off() {
    echo ""
    LOG_INFO "Powering off..."
    poweroff -f
}

# Check ublk devices and exit if not available
check_ublk_devices() {
    LOG_INFO "Checking ublk devices..."

    # Check if ublk-control exists
    if [ ! -e /dev/ublk-control ]; then
        LOG_ERROR "ublk-control device not found (/dev/ublk-control)"
        LOG_ERROR "ublk driver may not be loaded or kernel doesn't support ublk"
        power_off
    fi

    # Check if ublkb devices exist
    if ! ls /dev/ublkb* 1>/dev/null 2>&1; then
        LOG_ERROR "No ublk block devices found (/dev/ublkb*)"
        LOG_ERROR "Failed to create ublk devices - check ublk module and setup"
        power_off
    fi

    LOG_OK "ublk devices available: $(ls /dev/ublkb* 2>/dev/null | tr '\n' ' ')"
}

# Create test data files for COWCACHE
# Creates 3 identical files for COWCACHE/ublk testing
setup_testdata() {
    LOG_INFO "Setting up test data files..."

    mkdir -p /data

    # Create 3 identical 10MB test files using a loop
    if [ ! -f /data/testfile1.bin ]; then
        dd if=/dev/urandom of=/data/seed.bin bs=1M count=10 2>/dev/null
        for i in 1 2 3; do
            cp /data/seed.bin /data/testfile${i}.bin
        done
        rm /data/seed.bin
        LOG_OK "Created testfile[1-3].bin (10MB each, identical content)"
    else
        LOG_OK "Test files already exist"
    fi

    # Show file info
    ls -lh /data/testfile*.bin 2>/dev/null | sed 's/^/  /'

    # Create ublk loop devices for test files
    if [ -e /dev/ublk-control ]; then
        LOG_INFO "Creating ublk loop devices..."
        for i in 1 2 3; do
            ublk add -t loop -f /data/testfile${i}.bin -n $((i-1)) 2>/dev/null || \
                LOG_WARN "Failed to create ublk device for testfile${i}.bin"
        done
        LOG_OK "ublk devices created"
    fi
}

#==========================================
# Main Execution
#==========================================

main() {
    # Mount filesystems
    mount_filesystems

    # Load modules
    load_modules

    # Setup test data files
    setup_testdata

    # Check ublk devices exist
    check_ublk_devices

    # Show status
    print_status

    # Check for auto-test mode
    if grep -q "auto_test" /proc/cmdline 2>/dev/null || [ "$AUTO_TEST" = "1" ]; then
        run_auto_tests
        local exit_code=$?
        power_off
        exit $exit_code
    fi

    # Interactive mode: start shell
    setsid cttyhack /bin/sh || exec /bin/sh -l
}

# Run main
main
